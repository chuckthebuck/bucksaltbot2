# Local canary/dev defaults.
#
# Copy with:
#   bash scripts/setup-local-env.sh
#
# Keep real OAuth tokens, database passwords, and Toolforge secrets out of git.

ENABLE_MODULE_LOADING=1
BOT_NAME=buckbot-local
TOOL_NAME=buckbot-local
BOT_ADMIN_ACCOUNTS=chuckbot
SECRET_KEY=dev-insecure-secret-change-me
CHUCKBOT_LOCAL_SAFE_MODE=1
FLASK_DEBUG=1
BUCKBOT_HTTP_USER_AGENT=Buckbot-local/4.0 (https://github.com/chuckthebuck/bucksaltbot2; User:Alachuckthebuck)

# Optional override. If empty, enabled-modules.txt is used.
ENABLED_MODULES=

# Module HTTP user agents stay independent from the framework user agent.
FOUR_AWARD_HTTP_USER_AGENT=FourAwardHelper-local/0.1 (https://github.com/chuckthebuck/module4awardhelper; User:Alachuckthebuck)

# Local services. Start your own Redis/MariaDB if you want full app tests.
TOOL_REDIS_URI=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/9
CELERY_RESULT_BACKEND=redis://localhost:6379/9
TOOL_TOOLSDB_USER=user
TOOL_TOOLSDB_PASSWORD=password
TOOL_TOOLSDB_HOST=127.0.0.1
TOOL_TOOLSDB_DATABASE=chuckbot_local

# Local filesystem state.
TOOL_DATA_DIR=./data
PYWIKIBOT_DIR=./data/pywikibot

# Local canary should not write wiki status pages.
LIVE_TEST_DISABLE_STATUS_UPDATES=1

# OAuth credentials for live module/job runs. Leave blank for build canaries.
CONSUMER_TOKEN=
CONSUMER_SECRET=
ACCESS_TOKEN=
ACCESS_SECRET=
USER_OAUTH_CONSUMER_KEY=
USER_OAUTH_CONSUMER_SECRET=
