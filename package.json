{
  "name": "chuckbot-framework",
  "private": true,
  "version": "4.0.4",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "npm run modules:frontend && tsc && vite build",
    "modules:frontend": "node scripts/generate-module-frontend-registry.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint client-src --ext .ts,.vue",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.1.1"
  },
  "dependencies": {
    "vue": "^3.5.34",
    "@wikimedia/codex": "^2.5.1",
    "@wikimedia/codex-design-tokens": "^2.5.1",
    "less": "^4.6.4"
  }
}
